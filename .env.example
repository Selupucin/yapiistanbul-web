# Web app environment template — copy to .env.local for local dev.
# NEVER commit real secrets. In production set these in the Vercel dashboard.

NODE_ENV=development

# MongoDB (Atlas connection string)
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?appName=site
MONGODB_DB=yapi_istanbul

# Auth — generate a strong secret: `openssl rand -hex 32`
# In production a weak/empty JWT_SECRET makes the app fail closed (no login).
JWT_SECRET=change-me-with-a-32-byte-random-hex
JWT_EXPIRES_IN=7d

# Seed/default admin (used once to create the admin record if none exists)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password

# Public site URL (used for SEO metadata, sitemap, robots)
NEXT_PUBLIC_SITE_URL=https://yapiistanbul.com

# Rate limiting (optional) — Upstash Redis REST. If unset, limiting is disabled.
# Create a free DB at https://upstash.com -> REST section.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
